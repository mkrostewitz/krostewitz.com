# Public frontend config
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MAPBOX_TOKEN=

# IPinfo Lite token. Used server-side for country-based language detection.
IP_INFO_TOKEN=

# GitHub portfolio. Select visible repos in /admin/github-portfolio.
# GITHUB_PORTFOLIO_REPOS is only an optional bootstrap list before GitHub Portfolio settings are saved.
# GITHUB_TOKEN is optional for private repos or higher rate limits.
GITHUB_USERNAME=mkrostewitz
GITHUB_PORTFOLIO_REPOS=
GITHUB_TOKEN=

# Apple/iCloud SMTP. Required for contact verification, email 2FA, and magic links.
APPLE_MAIL_USER=
APPLE_MAIL_APP_PASSWORD=
APPLE_MAIL_FROM=
APPLE_MAIL_TO=

# MongoDB. Required for contact submissions, auth challenges, sessions, and posts.
MONGO_DB_URI=
MONGO_DB_NAME=
MONGO_DB_USER=
MONGO_DB_PASSWORD=

# DigitalOcean Spaces. Required for admin media and CV uploads.
DO_SPACES_BUCKET=
DO_SPACES_REGION=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_PUBLIC_URL=
DO_SPACES_UPLOAD_PREFIX=
DO_SPACES_CV_PREFIX=cv
POST_UPLOAD_MAX_BYTES=
CV_UPLOAD_MAX_BYTES=

# OpenAI. Required for AI-assisted post creation, editing, and translation.
OPENAI_API_KEY=
OPENAI_POSTS_MODEL=

# Admin authentication. User credentials are stored in the MongoDB users collection.
AUTH_SECRET=
AUTH_BASE_URL=
